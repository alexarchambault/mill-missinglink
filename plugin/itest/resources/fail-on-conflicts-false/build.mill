package build

import mill._
import mill.scalalib._
import io.github.alexarchambault.millmissinglink._

/** A project with failOnConflicts = false, so missinglinkCheck always succeeds. */
object foo extends ScalaModule with MissingLink {
  def scalaVersion = "2.13.16"

  override def missinglinkFailOnConflicts = Task { false }
}
